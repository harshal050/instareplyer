{
  "name": "@instareplyer/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --dir ../.. --filter @instareplyer/types build && pnpm --dir ../.. --filter @instareplyer/database build && tsc",
    "start": "node dist/server.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@instareplyer/types": "workspace:*",
    "@instareplyer/utils": "workspace:*",
    "@instareplyer/database": "workspace:*",
